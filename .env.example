# =============================================================================
# llm-stack – Environment Variables Template
# Copy thành .env và điền giá trị thực.
# KHÔNG commit file .env vào git!
# =============================================================================

# -----------------------------------------------------------------------------
# cf-ai-proxy
# REDIS_URL: Redis connection string (auto-set bởi docker-compose)
# Cấu hình tài khoản Cloudflare được thực hiện thông qua file:
#   services/cf-ai-proxy/accounts.csv (tự động hot-reload sau 5 giây)
# -----------------------------------------------------------------------------
REDIS_URL=redis://redis:6379

# -----------------------------------------------------------------------------
# OmniRoute
# Cấu hình bảo mật và password ban đầu của OmniRoute
# JWT_SECRET: Dùng để ký session cookie của dashboard (openssl rand -base64 48)
# API_KEY_SECRET: Khóa AES để mã hóa API keys của các provider (openssl rand -hex 32)
# INITIAL_PASSWORD: Mật khẩu ban đầu để đăng nhập admin dashboard (mặc định: llmstack2026)
# -----------------------------------------------------------------------------
OMNIROUTE_PORT=20128
JWT_SECRET=
API_KEY_SECRET=
INITIAL_PASSWORD=llmstack2026

# -----------------------------------------------------------------------------
# claude-proxy
# upstream_api_key phải khớp với key trong api_keys của OmniRoute
# (đã được seed trong init.sql)
# -----------------------------------------------------------------------------
CLAUDE_PROXY_PORT=20129
UPSTREAM_API_KEY=sk-e03c947dc728e9f5-1lt0v4-32e6f2f4

# -----------------------------------------------------------------------------
# Timezone
# -----------------------------------------------------------------------------
TZ=Asia/Ho_Chi_Minh
