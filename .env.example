# =============================================================================
# llm-stack – Environment Variables Template
# Copy thành .env và điền giá trị thực.
# KHÔNG commit file .env vào git!
# =============================================================================

# -----------------------------------------------------------------------------
# Cloudflare Workers AI – Tài khoản (cf-ai-proxy đọc từ accounts.csv)
# Các giá trị này cũng được 9router dùng nếu cần direct CF access
# -----------------------------------------------------------------------------
CF_ACCOUNT_1_ID=your_cf_account_id_1
CF_ACCOUNT_1_TOKEN=cfat_your_token_here_1

CF_ACCOUNT_2_ID=your_cf_account_id_2
CF_ACCOUNT_2_TOKEN=cfat_your_token_here_2

CF_ACCOUNT_3_ID=your_cf_account_id_3
CF_ACCOUNT_3_TOKEN=cfat_your_token_here_3

# -----------------------------------------------------------------------------
# cf-ai-proxy
# REDIS_URL: Redis connection string (auto-set bởi docker-compose)
# -----------------------------------------------------------------------------
REDIS_URL=redis://redis:6379

# -----------------------------------------------------------------------------
# 9router
# Password đăng nhập UI 9router (đã được hash trong init.sql)
# Nếu muốn đổi: docker exec -it llm-9router sh -c "..."
# Password mặc định trong init.sql: llmstack2026
# -----------------------------------------------------------------------------
NINE_ROUTER_PORT=20128

# -----------------------------------------------------------------------------
# claude-proxy
# upstream_api_key phải khớp với apiKey trong 9router settings
# (đã được seed trong init.sql)
# -----------------------------------------------------------------------------
CLAUDE_PROXY_PORT=20129
UPSTREAM_API_KEY=sk-e03c947dc728e9f5-1lt0v4-32e6f2f4

# -----------------------------------------------------------------------------
# Timezone
# -----------------------------------------------------------------------------
TZ=Asia/Ho_Chi_Minh
