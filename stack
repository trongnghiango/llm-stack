#!/bin/bash
# =============================================================================
# llm-stack Unified CLI Manager Tool
# =============================================================================
set -e

PROJECT_ROOT="$(cd "$(dirname "$0")" && pwd)"
cd "$PROJECT_ROOT"

# ANSI Color Codes
GREEN='\033[0;32m'
NC='\033[0m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
RED='\033[0;31m'

show_usage() {
    echo -e "${BLUE}llm-stack CLI Manager${NC}"
    echo "Sử dụng: ./stack [lệnh] [tùy chọn]"
    echo ""
    echo "Các lệnh hỗ trợ:"
    echo "  start             Khởi động toàn bộ dịch vụ (tự động seed DB nếu mới)"
    echo "  stop              Dừng và dọn dẹp các containers"
    echo "  restart [service] Khởi động lại toàn bộ hoặc một dịch vụ cụ thể (ví dụ: 9router, cf-ai-proxy)"
    echo "  status            Xem trạng thái hoạt động của các containers"
    echo "  logs [service]    Xem logs trực tiếp (tail logs) của toàn bộ hoặc một dịch vụ cụ thể"
    echo "  sync-nim          Đồng bộ tài khoản NVIDIA NIM từ CSV, tự động xóa cache Redis và restart 9router"
    echo "  flush             Xóa sạch bộ nhớ đệm (cache) trong Redis"
    echo "  help              Hiển thị hướng dẫn này"
    echo ""
    echo "Ví dụ:"
    echo "  ./stack start"
    echo "  ./stack sync-nim"
    echo "  ./stack logs cf-ai-proxy"
}

case "$1" in
    start)
        echo -e "${GREEN}🚀 Đang khởi chạy llm-stack...${NC}"
        ./start.sh
        ;;
    stop)
        echo -e "${YELLOW}🛑 Đang dừng llm-stack...${NC}"
        docker compose down
        echo -e "${GREEN}✅ Đã dừng thành công!${NC}"
        ;;
    restart)
        if [ -n "$2" ]; then
            echo -e "${GREEN}🔄 Đang khởi động lại dịch vụ: $2...${NC}"
            docker compose restart "$2"
        else
            echo -e "${GREEN}🔄 Đang khởi động lại toàn bộ stack...${NC}"
            docker compose restart
        fi
        echo -e "${GREEN}✅ Hoàn thành!${NC}"
        ;;
    status)
        echo -e "${BLUE}📊 Trạng thái các dịch vụ:${NC}"
        docker compose ps
        ;;
    logs)
        if [ -n "$2" ]; then
            docker compose logs -f --tail=100 "$2"
        else
            docker compose logs -f --tail=100
        fi
        ;;
    sync-nim)
        echo -e "${BLUE}🔍 Đang bắt đầu đồng bộ NVIDIA NIM từ CSV...${NC}"
        if [ -f "scripts/sync_nim_accounts.py" ]; then
            python3 scripts/sync_nim_accounts.py
            
            echo -e "${BLUE}🧹 Đang xóa sạch cache cũ trong Redis...${NC}"
            docker exec llm-redis redis-cli flushall >/dev/null || true
            
            echo -e "${GREEN}🔄 Khởi động lại 9router để nạp cấu hình mới...${NC}"
            docker compose restart 9router
            
            echo -e "${GREEN}🎉 Hoàn tất! NVIDIA NIM đã được đồng bộ và sẵn sàng hoạt động.${NC}"
        else
            echo -e "${RED}❌ Lỗi: Không tìm thấy file scripts/sync_nim_accounts.py${NC}"
            exit 1
        fi
        ;;
    flush)
        echo -e "${YELLOW}🧹 Đang xóa sạch bộ nhớ đệm (cache) Redis...${NC}"
        docker exec llm-redis redis-cli flushall
        echo -e "${GREEN}✅ Đã xóa sạch cache Redis!${NC}"
        ;;
    help|*)
        show_usage
        ;;
esac
